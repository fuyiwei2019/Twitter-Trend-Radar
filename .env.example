# 复制本文件为 .env，填入你自己的 key（.env 已被 .gitignore 忽略，不会提交）
# cp .env.example .env

# ---- 必需 ----
# Twitter 搜索：AISA Twitter Autopilot
# 获取： https://aisa.one/skills/twitter-autopilot
AISA_API_KEY=

# ---- 可选 ----
# 域名近三月流量（不填则不显示流量图）
# 获取： https://aitdk.com
AITDK_API_KEY=

# 域名注册时间 / 年龄（不填则域名显示「年龄未知」）
# 获取： https://query.domains
QUERY_DOMAINS_KEY=

# ---- 其它（一般不用改）----
# 监听端口
# PORT=8787

# 各接口 base（自建代理时才需要改）
# AISA_BASE=https://api.aisa.one/apis/v1
# AITDK_BASE=https://api.aitdk.com/api/v1
# QUERY_DOMAINS_BASE=https://api.query.domains/api/v1
